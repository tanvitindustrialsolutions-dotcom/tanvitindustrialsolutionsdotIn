# Copy to .env (same folder as package.json). File is gitignored — never commit real values.

# Set on the live server so the admin session cookie is HTTPS-only:
# NODE_ENV=production

# Required for production — strong unique password
ADMIN_PASSWORD=changeme

# Session signing secret (any long random string)
SESSION_SECRET=replace-with-random-string

# Optional — default 8787
# PORT=8787

# Comma-separated origins allowed to call API from browser.
# Example: https://tanvitindustrialsolutions.in,https://www.tanvitindustrialsolutions.in
CORS_ORIGIN=
