# Copy to .env (same folder as package.json). File is gitignored — never commit real values.

# Set on the live server so the admin session cookie is HTTPS-only:
# NODE_ENV=production

# Required for production — strong unique password
ADMIN_PASSWORD=changeme

# Session signing secret (any long random string)
SESSION_SECRET=replace-with-random-string

# Optional — default 8787
# PORT=8787

# Local only: allow “Commit & push to GitHub” in /admin/ (server runs git add / commit / push).
# Never enable on a public server unless you fully trust the machine and admin password.
# ALLOW_ADMIN_GIT_PUSH=1
# If .git is not above this folder, set absolute path to repo root (folder containing .git):
# GIT_REPO_ROOT=C:\BHANU
# Optional: PAT for HTTPS github.com remotes (not used for SSH remotes). Never commit the token.
# GIT_PUSH_TOKEN=
# GIT_PUSH_BRANCH=main
# Optional — used only for the automated “admin” commit (overrides missing git config):
# GIT_AUTHOR_NAME=Tanvit admin
# GIT_AUTHOR_EMAIL=you@example.com

# Comma-separated origins allowed to call API from browser.
# Example: https://tanvitindustrialsolutions.in,https://www.tanvitindustrialsolutions.in
CORS_ORIGIN=
